{
  "rules": {
    "dm": {
      "meta": {
        ".read": true,
        ".write": true,
        ".indexOn": ["updatedAt", "customerEmail"]
      },
      "threadMessages": {
        ".read": true,
        "$conversationId": {
          ".write": true,
          ".indexOn": ["createdAt"]
        }
      },
      "presence": {
        ".read": true,
        "$conversationId": {
          ".write": true,
          "admin": {
            ".write": true
          },
          "customer": {
            ".write": true
          }
        }
      },
      "magicLinks": {
        ".read": true,
        "$token": {
          ".write": true
        }
      }
    },
    "portfolioProjects": {
      ".read": true,
      ".write": "auth != null && auth.token.email == 'ruben.jim.co@gmail.com'"
    },
    "pipelineLeads": {
      ".read": "auth != null && auth.token.email == 'ruben.jim.co@gmail.com'",
      ".write": "auth != null && auth.token.email == 'ruben.jim.co@gmail.com'",
      ".indexOn": ["stage", "updatedAt", "createdAt"]
    },
    "agencyProjects": {
      ".read": "auth != null && auth.token.email == 'ruben.jim.co@gmail.com'",
      ".write": "auth != null && auth.token.email == 'ruben.jim.co@gmail.com'",
      ".indexOn": ["leadId", "updatedAt"],
      "$projectId": {
        ".read": true
      }
    },
    "agencyMatcherSubmissions": {
      ".read": "auth != null && auth.token.email == 'ruben.jim.co@gmail.com'",
      "$submissionId": {
        ".write": "!data.exists()"
      }
    },
    "agencyMaintenance": {
      ".read": true,
      ".write": true
    },
    "agencyReferrals": {
      ".read": "auth != null && auth.token.email == 'ruben.jim.co@gmail.com'",
      ".write": "auth != null && auth.token.email == 'ruben.jim.co@gmail.com'"
    },
    "agencyClientPortals": {
      ".read": "auth != null && auth.token.email == 'ruben.jim.co@gmail.com'",
      ".write": "auth != null && auth.token.email == 'ruben.jim.co@gmail.com'",
      "$token": {
        ".read": true
      }
    },
    "agencyBusinessDocuments": {
      ".read": true,
      ".write": "auth != null && auth.token.email == 'ruben.jim.co@gmail.com'"
    },
    "agencyFirebaseHealth": {
      ".read": "auth != null && auth.token.email == 'ruben.jim.co@gmail.com'",
      ".write": "auth != null && auth.token.email == 'ruben.jim.co@gmail.com'"
    }
  }
}
