{
  "rules": {
    "dm": {
      "meta": {
        ".read": true,
        ".write": true,
        ".indexOn": ["updatedAt", "customerEmail"]
      },
      "threadMessages": {
        ".read": true,
        "$conversationId": {
          ".write": true,
          ".indexOn": ["createdAt"]
        }
      },
      "presence": {
        ".read": true,
        "$conversationId": {
          ".write": true,
          "admin": {
            ".write": true
          },
          "customer": {
            ".write": true
          }
        }
      },
      "magicLinks": {
        ".read": true,
        "$token": {
          ".write": true
        }
      }
    },
    "portfolioProjects": {
      ".read": true,
      ".write": true
    },
    "pipelineLeads": {
      ".read": true,
      ".write": true,
      ".indexOn": ["stage", "updatedAt", "createdAt"]
    }
  }
}
